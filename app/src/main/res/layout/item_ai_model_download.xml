<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: icon + title/status + action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Icon -->
            <ImageView
                android:id="@+id/iv_ai_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_cfg_backup"
                android:contentDescription="@string/ai_model_title" />

            <!-- Text container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_ai_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />

                <TextView
                    android:id="@+id/tv_ai_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="Chưa tải"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Spinner while starting download -->
                <ProgressBar
                    android:id="@+id/progress_ai_spinner"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Delete button (only when downloaded) -->
                <ImageButton
                    android:id="@+id/btn_ai_delete"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_baseline_close"
                    android:contentDescription="@string/delete"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Download button -->
                <ImageButton
                    android:id="@+id/btn_ai_download"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_download"
                    android:contentDescription="@string/download" />

            </LinearLayout>
        </LinearLayout>

        <!-- Progress bar row (horizontal, shown during download) -->
        <LinearLayout
            android:id="@+id/layout_ai_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ProgressBar
                android:id="@+id/progress_ai_download"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                tools:progress="45" />

            <TextView
                android:id="@+id/tv_ai_progress_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                tools:text="Đang tải file 2/3: decoder_model.onnx (45%)" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
